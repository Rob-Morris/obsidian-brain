#!/usr/bin/env bash
#
# brain — thin dispatch CLI for Obsidian Brain.
#
# Resolves the active vault, finds its central managed runtime (DD-048),
# and exec's into a brain-core script. The dispatch contract is DD-049.
#
# Vault resolution order:  --vault <path>  →  $BRAIN_VAULT_ROOT  →  CWD walk
# All args pass through to the script unchanged, except --vault which is
# consumed and re-injected as an absolute path.

set -euo pipefail

BRAIN_CLI_VERSION="1.0.3"
BRAIN_INSTALL_REF="v0.49.0"

# Dispatch contract (DD-049 v1). hyphens here become underscores on disk.
DISPATCH_SUBCOMMANDS=(
    check create edit rename setup configure repair upgrade
    read migrate-naming fix-links
)

INSTALL_URL="${BRAIN_INSTALL_URL:-https://raw.githubusercontent.com/rob-morris/obsidian-brain/${BRAIN_INSTALL_REF}/install.sh}"

# ---------------------------------------------------------------------------
# Output helpers
# ---------------------------------------------------------------------------

err() { printf '%s\n' "$*" >&2; }
die() { err "$*"; exit 1; }

# ---------------------------------------------------------------------------
# CLI-only subcommands
# ---------------------------------------------------------------------------

print_help() {
    cat <<EOF
brain — dispatch CLI for Obsidian Brain (v${BRAIN_CLI_VERSION})

Usage:
  brain <subcommand> [args...]
  brain <subcommand> --vault <path> [args...]

Vault subcommands (dispatched to .brain-core/scripts/):
  check          create         edit           rename
  setup          configure      repair         upgrade
  session        read           migrate-naming fix-links

Machine-level commands:
  machine ...    Machine-level runtime maintenance (dispatched to machine.py).

CLI subcommands:
  install <path> Scaffold a new vault at <path> (wraps install.sh).
  doctor [--json] [--actionable] [--severity S]
               Machine-level health checks (+ current-vault check if in scope).
  version        Print CLI version (also: --version).
  --help, -h     This message.

Vault resolution order: --vault, then \$BRAIN_VAULT_ROOT, then CWD walk for
the nearest .brain-core/VERSION. --vault is forwarded as an absolute path.

Scripts in .brain-core/scripts/ remain authoritative; session without a direct
vault first uses the machine-level resolver, then dispatches to the resolved
Brain's own session.py. See docs/architecture/decisions/dd-049 and dd-054.
EOF
}

print_version() {
    printf 'brain %s\n' "$BRAIN_CLI_VERSION"
}

cli_install() {
    local target=${1:-}
    [[ -n "$target" ]] || die "usage: brain install <path>"
    shift
    command -v curl >/dev/null 2>&1 || die "brain install requires curl"
    bash <(curl -fsSL "$INSTALL_URL") "$target" "$@"
}

resolve_dispatch_targets() {
    # Sets CURRENT_VAULT and SOURCE_VAULT globals for the chosen helper.
    local launcher=${1:-}
    local helper_name=${2:?helper name required}

    CURRENT_VAULT=""
    if [[ -n "$VAULT_ARG" ]]; then
        [[ -d "$VAULT_ARG" ]] || die "brain: --vault path does not exist: $VAULT_ARG"
        CURRENT_VAULT=$(absolute_path "$VAULT_ARG")
    else
        CURRENT_VAULT=$(resolve_vault_silent || true)
    fi

    SOURCE_VAULT=""
    if [[ -n "$CURRENT_VAULT" && -f "$CURRENT_VAULT/.brain-core/scripts/$helper_name" ]]; then
        SOURCE_VAULT=$CURRENT_VAULT
    else
        SOURCE_VAULT=$(resolve_machine_source_vault_silent "$launcher" "$helper_name" || true)
    fi
}

render_cli_doctor_basics() {
    local launcher=${1:-}
    local rc=0
    printf 'brain CLI: %s\n' "$BRAIN_CLI_VERSION"
    printf '  binary:  %s\n' "${BASH_SOURCE[0]}"

    local brain_dir
    brain_dir=$(cd "$(dirname "${BASH_SOURCE[0]}")" 2>/dev/null && pwd -P)         || brain_dir=$(dirname "${BASH_SOURCE[0]}")
    case ":${PATH}:" in
        *":${brain_dir}:"*) printf '  PATH:    ok (%s on PATH)\n' "$brain_dir" ;;
        *) printf '  PATH:    WARN (%s not on PATH)\n' "$brain_dir"; rc=1 ;;
    esac

    if [[ -n "$launcher" ]]; then
        printf 'python:    %s (%s)\n' "$launcher" "$($launcher --version 2>&1)"
    else
        printf 'python:    MISSING (need python3.12+ on PATH)\n'
        rc=1
    fi
    return $rc
}

forwarded_args_include() {
    local needle=$1
    local arg
    for arg in "${FORWARDED_ARGS[@]+"${FORWARDED_ARGS[@]}"}"; do
        if [[ "$arg" == "$needle" ]]; then
            return 0
        fi
    done
    return 1
}

requested_json() {
    forwarded_args_include "--json"
}

try_exec_doctor_helper() {
    local source_vault=$1
    local current_vault=$2
    local launcher=$3
    local doctor_python
    doctor_python=$(try_resolve_vault_python "$source_vault" || true)
    if [[ -z "$doctor_python" ]]; then
        printf -v DOCTOR_HANDOFF_REASON 'source Brain found at %s but its runtime is unavailable — run `brain repair runtime --vault %s`' "$source_vault" "$source_vault"
        return 1
    fi

    local doctor_args=(--vault "$source_vault" --launcher "$launcher" --binary "${BASH_SOURCE[0]}" --cli-version "$BRAIN_CLI_VERSION")
    if [[ -n "$current_vault" ]]; then
        doctor_args+=(--current-vault "$current_vault")
    fi
    if (( ${#FORWARDED_ARGS[@]} > 0 )); then
        doctor_args+=("${FORWARDED_ARGS[@]}")
    fi
    exec "$doctor_python" "$source_vault/.brain-core/scripts/doctor.py" "${doctor_args[@]}"
}

render_degraded_doctor() {
    local current_vault=$1
    local launcher=${2:-}
    local rc=0
    local last=0
    render_cli_doctor_basics "$launcher" || { last=$?; (( last > rc )) && rc=$last; }

    # Shell fallback cannot safely import the Python-owned `_common._venv`
    # contract here, so it keeps the historic user-home summary only.
    local venvs_root="$HOME/.brain/venvs"
    printf '\nmachine diagnosis:\n'
    printf '  doctor handoff unavailable — showing shell-only shared-runtime summary\n'
    if [[ -n "${DOCTOR_HANDOFF_REASON:-}" ]]; then
        printf '  %s\n' "$DOCTOR_HANDOFF_REASON"
        rc=1
    fi
    if [[ -d "$venvs_root" ]]; then
        local count
        count=$(find "$venvs_root" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | wc -l | tr -d ' ')
        printf 'venvs:     %s (%s present)\n' "$venvs_root" "$count"
    else
        printf 'venvs:     not yet provisioned (%s)\n' "$venvs_root"
    fi

    printf '\nvault diagnosis:\n'
    if [[ -n "$current_vault" ]]; then
        printf '  %s\n' "$current_vault"
        local check_py="$current_vault/.brain-core/scripts/check.py"
        if [[ -f "$check_py" ]]; then
            local vault_python
            vault_python=$(resolve_vault_python "$current_vault") || return 1
            "$vault_python" "$check_py" --vault "$current_vault" ${FORWARDED_ARGS[@]+"${FORWARDED_ARGS[@]}"} || { last=$?; (( last > rc )) && rc=$last; }
        else
            printf '  check.py missing — vault may be on an older brain-core\n'
            rc=1
        fi
    else
        printf '  none in scope (run inside a vault or pass --vault)\n'
    fi
    return $rc
}

dispatch_machine() {
    extract_vault_arg "$@"

    local py
    py=$(find_launcher_python || true)
    [[ -n "$py" ]] || die "brain: no python3.12+ launcher on PATH (need python3.12 or python3.13)"

    resolve_dispatch_targets "$py" machine.py
    [[ -n "$SOURCE_VAULT" ]] || die "brain: no source Brain with machine.py found — run inside a modern Brain or upgrade one registered Brain first"

    local source_python
    source_python=$(resolve_vault_python "$SOURCE_VAULT")

    local script_path="$SOURCE_VAULT/.brain-core/scripts/machine.py"
    local machine_args=(--vault "$SOURCE_VAULT" --launcher "$py")
    if [[ -n "$CURRENT_VAULT" ]]; then
        machine_args+=(--current-vault "$CURRENT_VAULT")
    fi
    if (( ${#FORWARDED_ARGS[@]} > 0 )); then
        machine_args+=("${FORWARDED_ARGS[@]}")
    fi
    exec "$source_python" "$script_path" "${machine_args[@]}"
}

cli_doctor() {
    extract_vault_arg "$@"

    local py
    py=$(find_launcher_python || true)
    resolve_dispatch_targets "$py" doctor.py
    DOCTOR_HANDOFF_REASON=""

    if [[ -n "$py" && -n "$SOURCE_VAULT" ]]; then
        try_exec_doctor_helper "$SOURCE_VAULT" "$CURRENT_VAULT" "$py" || true
    fi

    if requested_json; then
        die "brain: doctor JSON output requires a source Brain with doctor.py — run inside a modern Brain or upgrade one registered Brain first"
    fi

    render_degraded_doctor "$CURRENT_VAULT" "$py"
}

# ---------------------------------------------------------------------------
# Vault + runtime resolution
# ---------------------------------------------------------------------------

# Walk upward from $1 looking for .brain-core/VERSION. Print path on success.
walk_for_vault() {
    local dir=$1
    while [[ "$dir" != "/" && -n "$dir" ]]; do
        if [[ -f "$dir/.brain-core/VERSION" ]]; then
            printf '%s\n' "$dir"
            return 0
        fi
        dir=$(dirname "$dir")
    done
    return 1
}

# Resolve to absolute path without realpath (which is non-portable).
absolute_path() {
    local p=$1
    if [[ -d "$p" ]]; then
        (cd "$p" && pwd -P)
    else
        local d
        d=$(dirname "$p")
        (cd "$d" && printf '%s/%s\n' "$(pwd -P)" "$(basename "$p")")
    fi
}

resolve_vault_silent() {
    local candidate=${BRAIN_VAULT_ROOT:-}
    if [[ -n "$candidate" ]]; then
        absolute_path "$candidate"
        return 0
    fi
    walk_for_vault "$(pwd -P)"
}

machine_vault_registry_path() {
    local xdg=${XDG_CONFIG_HOME:-}
    if [[ -n "$xdg" && "$xdg" = /* ]]; then
        printf '%s/brain/vaults\n' "$xdg"
    else
        printf '%s/.config/brain/vaults\n' "$HOME"
    fi
}

machine_brains_registry_path() {
    local xdg=${XDG_CONFIG_HOME:-}
    if [[ -n "$xdg" && "$xdg" = /* ]]; then
        printf '%s/brain/brains.json\n' "$xdg"
    else
        printf '%s/.config/brain/brains.json\n' "$HOME"
    fi
}

resolve_machine_source_vault_silent() {
    local launcher=${1:-}
    local helper_name=${2:-doctor_machine.py}
    local registry_path
    registry_path=$(machine_vault_registry_path)

    if [[ -f "$registry_path" ]]; then
        # This duplicates the on-disk registry parsing contract from
        # src/brain-core/scripts/vault_registry.py because machine-level CLI
        # commands need a source Brain before they can hand off to Python at all.
        # Current writer contract is: <brain-id>\tlocal\t<absolute-vault-path>.
        # Legacy two-column entries are still treated as implicit local entries.
        local brain_id kind value
        while IFS=$'	' read -r brain_id kind value; do
            [[ -n "$brain_id" ]] || continue
            [[ "$brain_id" == \#* ]] && continue
            if [[ -z "$value" ]]; then
                value=$kind
                kind=local
            fi
            [[ "$kind" == "local" ]] || continue
            [[ -n "$value" ]] || continue
            if [[ -f "$value/.brain-core/VERSION" && -f "$value/.brain-core/scripts/$helper_name" ]]; then
                absolute_path "$value"
                return 0
            fi
        done < "$registry_path"
    fi

    [[ -n "$launcher" ]] || return 1

    local brains_path
    brains_path=$(machine_brains_registry_path)
    [[ -f "$brains_path" ]] || return 1

    # The shell only needs a dispatchable source Brain here. Version/schema
    # validation for brains.json stays in the Python-owned _machine registry
    # loader after handoff succeeds.
    local fallback
    fallback=$("$launcher" -c 'import json, os, sys
path = sys.argv[1]
try:
    with open(path, "r", encoding="utf-8") as handle:
        data = json.load(handle)
except (OSError, ValueError):
    raise SystemExit(1)
brains = data.get("brains")
if not isinstance(brains, list):
    raise SystemExit(1)
helper_name = sys.argv[2]
for entry in brains:
    if not isinstance(entry, dict):
        continue
    vault_path = entry.get("path")
    if not isinstance(vault_path, str) or not vault_path:
        continue
    version_path = os.path.join(vault_path, ".brain-core", "VERSION")
    helper_path = os.path.join(vault_path, ".brain-core", "scripts", helper_name)
    if os.path.isfile(version_path) and os.path.isfile(helper_path):
        print(os.path.realpath(vault_path))
        raise SystemExit(0)
raise SystemExit(1)' "$brains_path" "$helper_name" 2>/dev/null || true)
    [[ -n "$fallback" ]] || return 1
    printf '%s\n' "$fallback"
}


find_launcher_python() {
    # Return an absolute path to a Python 3.12+ interpreter, or fail.
    # `command -v` resolves PATH tokens like 'python3.12' to absolute paths;
    # we then probe each candidate's version. `python3` in particular may be
    # anything from 3.0 to 3.13, so probing is the only honest accept.
    # DD-048 makes 3.12 the contract; running scripts under older interpreters
    # corrupts the central-venv tag and silently produces wrong results.
    if [[ -n "${BRAIN_VENV_LAUNCHER:-}" ]]; then
        printf '%s\n' "$BRAIN_VENV_LAUNCHER"
        return 0
    fi
    local candidate resolved
    for candidate in python3.13 python3.12 python3; do
        resolved=$(command -v "$candidate" 2>/dev/null) || continue
        if "$resolved" -c 'import sys; sys.exit(0 if sys.version_info >= (3, 12) else 1)' >/dev/null 2>&1; then
            printf '%s\n' "$resolved"
            return 0
        fi
    done
    return 1
}

_resolve_vault_python_inner() {
    local vault=$1
    local venv_helper="$vault/.brain-core/scripts/_common/_venv.py"
    [[ -f "$venv_helper" ]] || return 1
    local launcher
    launcher=$(find_launcher_python) || return 1
    "$launcher" "$venv_helper" runnable-python --vault "$vault" --launcher "$launcher"
}

resolve_vault_python() {
    local vault=$1
    local resolved
    if ! resolved=$(_resolve_vault_python_inner "$vault"); then
        local venv_helper="$vault/.brain-core/scripts/_common/_venv.py"
        [[ -f "$venv_helper" ]] || die "brain: vault has no _venv.py helper — upgrade brain-core (path: $venv_helper)"
        find_launcher_python >/dev/null || die "brain: no python3.12+ launcher on PATH (need python3.12 or python3.13)"
        die "brain: no runnable python for vault $vault — run 'brain repair runtime --vault $vault' or 'bash install.sh $vault'"
    fi
    printf '%s\n' "$resolved"
}

try_resolve_vault_python() {
    local vault=$1
    _resolve_vault_python_inner "$vault"
}

machine_resolution_runtime_root() {
    if [[ -n "${BRAIN_RESOLUTION_RUNTIME_DIR:-}" ]]; then
        if [[ "$BRAIN_RESOLUTION_RUNTIME_DIR" = /* ]]; then
            printf '%s\n' "$BRAIN_RESOLUTION_RUNTIME_DIR"
        else
            printf '%s/%s\n' "$(pwd -P)" "$BRAIN_RESOLUTION_RUNTIME_DIR"
        fi
    else
        printf '%s/.brain/resolution-runtime\n' "$HOME"
    fi
}

machine_resolution_runtime_entry() {
    printf '%s/resolve_brain.py\n' "$(machine_resolution_runtime_root)"
}

session_forwarded_workspace_dir() {
    local i arg
    for (( i = 0; i < ${#FORWARDED_ARGS[@]}; i++ )); do
        arg=${FORWARDED_ARGS[$i]}
        case "$arg" in
            --workspace-dir|--project-dir)
                if (( i + 1 < ${#FORWARDED_ARGS[@]} )); then
                    printf '%s\n' "${FORWARDED_ARGS[$((i + 1))]}"
                else
                    die "brain: $arg requires a value"
                fi
                return 0
                ;;
            --workspace-dir=*)
                printf '%s\n' "${arg#--workspace-dir=}"
                return 0
                ;;
            --project-dir=*)
                printf '%s\n' "${arg#--project-dir=}"
                return 0
                ;;
        esac
    done
    return 1
}

json_escape() {
    local value=${1-}
    value=${value//\\/\\\\}
    value=${value//\"/\\\"}
    value=${value//$'\n'/\\n}
    value=${value//$'\r'/\\r}
    value=${value//$'\t'/\\t}
    printf '%s' "$value"
}

emit_session_resolution_json_fallback() {
    # Keep this minimal Bash JSON shape aligned with
    # src/brain-core/scripts/_machine/resolve_brain.py:resolve_payload().
    # It exists for failures before Python can run at all.
    local message=$1
    local code=$2
    local action=$3
    local command=$4
    local start_dir
    start_dir=$(pwd -P)
    local workspace_env=${SESSION_RESOLUTION_WORKSPACE_DIR:-${BRAIN_WORKSPACE_DIR:-}}
    local vault_root_env=${BRAIN_VAULT_ROOT:-}
    local workspace_json vault_json
    if [[ -n "$workspace_env" ]]; then
        workspace_json="\"$(json_escape "$workspace_env")\""
    else
        workspace_json="null"
    fi
    if [[ -n "$vault_root_env" ]]; then
        vault_json="\"$(json_escape "$vault_root_env")\""
    else
        vault_json="null"
    fi
    printf '{"status":"degraded","recovery_class":"session_resolution","vault_root":null,"message":"%s","session_resolution":{"code":"%s","context":{"workspace_env":%s,"vault_root_env":%s,"start_dir":"%s","workspace_anchor_explicit":%s,"vault_root_explicit":%s}},"recovery":{"action":"%s","command":"%s"}}\n' \
        "$(json_escape "$message")" \
        "$(json_escape "$code")" \
        "$workspace_json" \
        "$vault_json" \
        "$(json_escape "$start_dir")" \
        "$([[ -n "$workspace_env" ]] && printf true || printf false)" \
        "$([[ -n "$vault_root_env" ]] && printf true || printf false)" \
        "$(json_escape "$action")" \
        "$(json_escape "$command")"
}

emit_session_resolution_error() {
    local launcher=${1:-}
    local message=$2
    local code=$3
    local action=$4
    local command=$5
    if requested_json; then
        if [[ -z "$launcher" ]]; then
            emit_session_resolution_json_fallback "$message" "$code" "$action" "$command"
            exit 0
        fi
        "$launcher" -c 'import json, sys
import os
context = {
    "workspace_env": os.environ.get("SESSION_RESOLUTION_WORKSPACE_DIR") or os.environ.get("BRAIN_WORKSPACE_DIR") or None,
    "vault_root_env": os.environ.get("BRAIN_VAULT_ROOT") or None,
    "start_dir": os.getcwd(),
}
context["workspace_anchor_explicit"] = bool(context["workspace_env"])
context["vault_root_explicit"] = bool(context["vault_root_env"])
print(json.dumps({
    "status": "degraded",
    "recovery_class": "session_resolution",
    "vault_root": None,
    "message": sys.argv[1],
    "session_resolution": {
        "code": sys.argv[2],
        "context": context,
    },
    "recovery": {
        "action": sys.argv[3],
        "command": sys.argv[4],
    },
}, ensure_ascii=False))' "$message" "$code" "$action" "$command"
        exit 0
    else
        err "brain: $message"
        err "$action"
        err "$command"
    fi
    exit 2
}

session_extract_payload() {
    local launcher=$1
    local payload=$2
    eval "$("$launcher" -c 'import json, shlex, sys
data = json.loads(sys.argv[1])
def get(path):
    value = data
    for part in path.split("."):
        if isinstance(value, dict):
            value = value.get(part)
        else:
            return ""
    if value is None:
        return ""
    if isinstance(value, bool):
        return "true" if value else "false"
    return str(value)
fields = {
    "SESSION_STATUS": get("status"),
    "SESSION_MESSAGE": get("message"),
    "SESSION_CODE": get("session_resolution.code"),
    "SESSION_ACTION": get("recovery.action"),
    "SESSION_COMMAND": get("recovery.command"),
    "SESSION_TARGET_KIND": get("target.kind"),
    "SESSION_TARGET_VAULT": get("target.vault_root"),
    "SESSION_TARGET_WORKSPACE": get("target.workspace_dir"),
}
for key, value in fields.items():
    print(f"{key}={shlex.quote(value)}")' "$payload")"
}

# ---------------------------------------------------------------------------
# Dispatch
# ---------------------------------------------------------------------------

is_dispatch_subcommand() {
    local needle=$1
    local s
    for s in "${DISPATCH_SUBCOMMANDS[@]}"; do
        [[ "$s" == "$needle" ]] && return 0
    done
    return 1
}

# Split argv around --vault. Sets globals VAULT_ARG and FORWARDED_ARGS.
extract_vault_arg() {
    VAULT_ARG=""
    FORWARDED_ARGS=()
    while (( $# > 0 )); do
        case "$1" in
            --vault)
                [[ $# -ge 2 ]] || die "brain: --vault requires a value"
                VAULT_ARG=$2
                shift 2
                ;;
            --vault=*)
                VAULT_ARG=${1#--vault=}
                shift
                ;;
            *)
                FORWARDED_ARGS+=("$1")
                shift
                ;;
        esac
    done
}

dispatch() {
    local subcommand=$1
    shift
    extract_vault_arg "$@"

    local vault
    if [[ -n "$VAULT_ARG" ]]; then
        [[ -d "$VAULT_ARG" ]] || die "brain: --vault path does not exist: $VAULT_ARG"
        vault=$(absolute_path "$VAULT_ARG")
    else
        vault=$(resolve_vault_silent || true)
        [[ -n "$vault" ]] || die "brain: no vault found — pass --vault <path>, set BRAIN_VAULT_ROOT, or run from inside a vault"
    fi

    local script_name=${subcommand//-/_}.py
    local script_path="$vault/.brain-core/scripts/$script_name"
    [[ -f "$script_path" ]] || die "brain: this brain-core version does not ship $script_name (vault: $vault)"

    local vault_python
    vault_python=$(resolve_vault_python "$vault")

    exec "$vault_python" "$script_path" --vault "$vault" ${FORWARDED_ARGS[@]+"${FORWARDED_ARGS[@]}"}
}

dispatch_session_to_vault() {
    local vault=$1
    shift
    local script_path="$vault/.brain-core/scripts/session.py"
    [[ -f "$script_path" ]] || die "brain: this brain-core version does not ship session.py (vault: $vault)"

    local vault_python
    vault_python=$(resolve_vault_python "$vault")
    exec "$vault_python" "$script_path" --vault "$vault" "$@"
}

dispatch_session() {
    extract_vault_arg "$@"

    local vault
    if [[ -n "$VAULT_ARG" ]]; then
        [[ -d "$VAULT_ARG" ]] || die "brain: --vault path does not exist: $VAULT_ARG"
        vault=$(absolute_path "$VAULT_ARG")
        dispatch_session_to_vault "$vault" ${FORWARDED_ARGS[@]+"${FORWARDED_ARGS[@]}"}
    fi

    local forwarded_workspace_dir
    forwarded_workspace_dir=$(session_forwarded_workspace_dir || true)
    if [[ -n "$forwarded_workspace_dir" && -z "${BRAIN_WORKSPACE_DIR:-}" ]]; then
        export SESSION_RESOLUTION_WORKSPACE_DIR="$forwarded_workspace_dir"
    else
        unset SESSION_RESOLUTION_WORKSPACE_DIR
    fi

    if [[ -z "${BRAIN_WORKSPACE_DIR:-}" && -z "$forwarded_workspace_dir" ]]; then
        if [[ -n "${BRAIN_VAULT_ROOT:-}" ]]; then
            [[ -d "$BRAIN_VAULT_ROOT" ]] || die "brain: BRAIN_VAULT_ROOT path does not exist: $BRAIN_VAULT_ROOT"
            vault=$(absolute_path "$BRAIN_VAULT_ROOT")
            dispatch_session_to_vault "$vault" ${FORWARDED_ARGS[@]+"${FORWARDED_ARGS[@]}"}
        fi

        vault=$(walk_for_vault "$(pwd -P)" || true)
        if [[ -n "$vault" ]]; then
            dispatch_session_to_vault "$vault" ${FORWARDED_ARGS[@]+"${FORWARDED_ARGS[@]}"}
        fi
    fi

    local launcher
    launcher=$(find_launcher_python || true)
    [[ -n "$launcher" ]] || emit_session_resolution_error "" \
        "no python3.12+ launcher available for machine-level Brain resolution" \
        "filesystem_access" \
        "Install or repair the Brain CLI runtime, then rerun brain session." \
        "brain doctor --actionable"

    local resolver_entry
    resolver_entry=$(machine_resolution_runtime_entry)
    [[ -f "$resolver_entry" ]] || emit_session_resolution_error "$launcher" \
        "machine-level Brain resolution runtime is not installed" \
        "filesystem_access" \
        "Install or upgrade a Brain so the machine resolution runtime is provisioned, then rerun brain session." \
        "brain install <vault> or brain upgrade --vault <vault>"

    local payload
    local resolver_env=()
    if [[ -n "$forwarded_workspace_dir" && -z "${BRAIN_WORKSPACE_DIR:-}" ]]; then
        resolver_env=(BRAIN_WORKSPACE_DIR="$forwarded_workspace_dir")
    fi
    if ! payload=$(env ${resolver_env[@]+"${resolver_env[@]}"} "$launcher" "$resolver_entry" --start-dir "$(pwd -P)" --json); then
        emit_session_resolution_error "$launcher" \
            "machine-level Brain resolution failed before returning a payload" \
            "filesystem_access" \
            "Repair or reprovision the machine resolution runtime, then rerun brain session." \
            "brain doctor --actionable"
    fi

    session_extract_payload "$launcher" "$payload"
    : "${SESSION_STATUS:=}"
    : "${SESSION_MESSAGE:=machine-level Brain resolution returned an unreadable payload}"
    : "${SESSION_CODE:=filesystem_access}"
    : "${SESSION_ACTION:=Repair or reprovision the machine resolution runtime, then rerun brain session.}"
    : "${SESSION_COMMAND:=brain doctor --actionable}"
    if [[ "$SESSION_STATUS" != "ok" ]]; then
        if requested_json; then
            printf '%s\n' "$payload"
            exit 0
        fi
        emit_session_resolution_error "$launcher" "$SESSION_MESSAGE" "$SESSION_CODE" "$SESSION_ACTION" "$SESSION_COMMAND"
    fi

    # Remote seam — see DD-054. Non-MCP session only supports local targets in this slice.
    if [[ "$SESSION_TARGET_KIND" != "local" ]]; then
        emit_session_resolution_error "$launcher" \
            "remote Brain targets are not yet supported by brain session" \
            "remote_unsupported" \
            "Use MCP/API access for this remote Brain until non-MCP remote session support lands." \
            "brain doctor --actionable"
    fi

    # Remote seam / cross-process boundary — see DD-054. A local target without
    # vault_root is a resolver bug, not a user-repairable binding failure.
    [[ -n "$SESSION_TARGET_VAULT" ]] || die "brain: Brain resolution returned local target without vault_root"

    local session_args=()
    if [[ -n "$SESSION_TARGET_WORKSPACE" && -z "$forwarded_workspace_dir" ]]; then
        session_args+=(--workspace-dir "$SESSION_TARGET_WORKSPACE")
    fi
    if (( ${#FORWARDED_ARGS[@]} > 0 )); then
        session_args+=("${FORWARDED_ARGS[@]}")
    fi

    unset SESSION_RESOLUTION_WORKSPACE_DIR
    dispatch_session_to_vault "$SESSION_TARGET_VAULT" ${session_args[@]+"${session_args[@]}"}
}

# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------

main() {
    if (( $# == 0 )); then
        print_help
        exit 0
    fi

    local subcommand=$1
    shift

    case "$subcommand" in
        --help|-h|help) print_help ;;
        --version|version) print_version ;;
        install) cli_install "$@" ;;
        doctor) cli_doctor "$@" ;;
        machine) dispatch_machine "$@" ;;
        session) dispatch_session "$@" ;;
        *)
            if is_dispatch_subcommand "$subcommand"; then
                dispatch "$subcommand" "$@"
            else
                err "brain: unknown subcommand: $subcommand"
                err ""
                print_help >&2
                exit 2
            fi
            ;;
    esac
}

main "$@"

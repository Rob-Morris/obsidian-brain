#!/usr/bin/env bash
#
# Pre-commit hook: verifies .canary--pre-commit covers all bracket IDs
# defined in docs/canaries/pre-commit.md.
#
# The canary brief is the source of truth — adding a new [id] there
# automatically enforces it here.

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
CANARY_DEF="$REPO_ROOT/docs/canaries/pre-commit.md"
CANARY_LOG="$REPO_ROOT/.canary--pre-commit"

if [[ ! -f "$CANARY_DEF" ]]; then
  echo "pre-commit: docs/canaries/pre-commit.md not found — skipping canary check"
  exit 0
fi

# Extract all [id] patterns from the Items section (between ## Items and ## Log)
items_section=$(sed -n '/^## Items$/,/^## Log$/p' "$CANARY_DEF")
expected_ids=($(echo "$items_section" | grep -oE '\[[0-9]+[a-z]?\]' | sort -u))

if [[ ${#expected_ids[@]} -eq 0 ]]; then
  echo "pre-commit: no bracket IDs found in docs/canaries/pre-commit.md — skipping"
  exit 0
fi

# Check canary log exists
if [[ ! -f "$CANARY_LOG" ]]; then
  echo ""
  echo "pre-commit: .canary--pre-commit not found."
  echo ""
  echo "Read docs/canaries/pre-commit.md and write .canary--pre-commit"
  echo "confirming you've followed each item. Format:"
  echo ""
  echo "  [1] Label: done"
  echo "  [2] Label: skip, reason"
  echo ""
  exit 1
fi

# Check each expected ID is present in the log
missing=()
for id in "${expected_ids[@]}"; do
  if ! grep -qF "$id" "$CANARY_LOG" 2>/dev/null; then
    missing+=("$id")
  fi
done

if [[ ${#missing[@]} -gt 0 ]]; then
  echo ""
  echo "pre-commit: .canary--pre-commit is missing these items:"
  for item in "${missing[@]}"; do
    echo "  $item"
  done
  echo ""
  echo "Mark each as '[id] Label: done' or '[id] Label: skip, reason'."
  exit 1
fi

# Validate format: each bracketed line must have a label and status
bad=()
while IFS= read -r line; do
  trimmed="${line#"${line%%[![:space:]]*}"}"
  if [[ "$trimmed" =~ ^\[[0-9]+[a-z]?\] ]]; then
    if ! echo "$trimmed" | grep -qE '^\[[0-9]+[a-z]?\] .+: (done([, ] ?.+)?|skip, ?.+)$'; then
      bad+=("$line")
    fi
  fi
done < "$CANARY_LOG"

if [[ ${#bad[@]} -gt 0 ]]; then
  echo ""
  echo "pre-commit: these lines have invalid format:"
  for line in "${bad[@]}"; do
    echo "  $line"
  done
  echo ""
  echo "Expected: [id] Label: done  or  [id] Label: skip, reason"
  exit 1
fi

# Clean up — remove canary log so it can't go stale
rm -f "$CANARY_LOG"

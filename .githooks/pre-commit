#!/usr/bin/env bash
#
# Pre-commit hook: verifies .canary--pre-commit covers all numbered items
# defined in docs/canaries/pre-commit.md.
#
# The canary file is the source of truth — adding a new numbered item there
# automatically enforces it here.

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
CANARY_DEF="$REPO_ROOT/docs/canaries/pre-commit.md"
CANARY_LOG="$REPO_ROOT/.canary--pre-commit"

# Extract required item count from the canary definition
if [[ ! -f "$CANARY_DEF" ]]; then
  echo "pre-commit: docs/canaries/pre-commit.md not found — skipping canary check"
  exit 0
fi

# Count numbered items (lines starting with digit followed by period)
item_count=$(grep -cE '^[0-9]+\.' "$CANARY_DEF" || true)

if [[ "$item_count" -eq 0 ]]; then
  echo "pre-commit: no numbered items found in docs/canaries/pre-commit.md — skipping"
  exit 0
fi

# Check canary log exists
if [[ ! -f "$CANARY_LOG" ]]; then
  echo ""
  echo "pre-commit: .canary--pre-commit not found."
  echo ""
  echo "Read docs/canaries/pre-commit.md and write .canary--pre-commit"
  echo "confirming you've followed each item. Format:"
  echo ""
  echo "  [1] done"
  echo "  [2] skip: reason"
  echo ""
  exit 1
fi

# Check each required item is present
missing=()
for i in $(seq 1 "$item_count"); do
  if ! grep -qE "^\[$i\]" "$CANARY_LOG" 2>/dev/null; then
    missing+=("[$i]")
  fi
done

if [[ ${#missing[@]} -gt 0 ]]; then
  echo ""
  echo "pre-commit: .canary--pre-commit is missing these items:"
  for item in "${missing[@]}"; do
    echo "  $item"
  done
  echo ""
  echo "Mark each as 'done' or 'skip: reason' in .canary--pre-commit."
  exit 1
fi

# Check each item has 'done' or 'skip'
bad=()
while IFS= read -r line; do
  if [[ "$line" =~ ^\[[0-9]+\] && ! "$line" =~ (done|skip) ]]; then
    bad+=("$line")
  fi
done < "$CANARY_LOG"

if [[ ${#bad[@]} -gt 0 ]]; then
  echo ""
  echo "pre-commit: these lines need 'done' or 'skip: reason':"
  for line in "${bad[@]}"; do
    echo "  $line"
  done
  exit 1
fi

# Clean up — remove canary log so it can't go stale
rm -f "$CANARY_LOG"

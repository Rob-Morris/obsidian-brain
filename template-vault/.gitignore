# Obsidian — workspace and device-specific state
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/graph.json
.obsidian/backlink.json

# Obsidian — plugin runtime data (not config)
.obsidian/plugins/*/data.json

# Obsidian trash
.trash/

# macOS
.DS_Store

# Vault backups (large zips, not useful in git)
.backups/

# Skill workspace artefacts (eval outputs, benchmarks)
_Config/Skills/*-workspace/

# Compiled router (local, environment-specific, hash-invalidated)
_Config/.compiled-router.json

# Retrieval index (local, built by build_index.py)
_Config/.retrieval-index.json

# Canary log files (consumed by hooks, not vault content)
.canary--*
